# Generic git ignore rules
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
tmp/
temp/
*.tmp
.git/

# IDE configurations
.idea/
.vscode/  # Opcional: puedes dejar .gitignore en root, pero no las configuras de VSCode
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
bundle/

# Backend (Spring Boot)
/target/
/*.jar
/bin/
dist/
spring-boot.log
h2.db

# BFF / Frontend (Node.js)
node_modules/
npm-debug.log*/
yarn-error.log
.lint-stagedrc.js  # Si existe, es config de linting local
dist/
build/
.cache/coverage
.nyc_output/
test-report.xml

# Frontend (Angular) - específico
.angular/
src/app/**/*.ts.swp  # archivos temporales de edición
e2e/*.log

# Docker
.docker/
docker-compose.override.yml  # Solo para desarrollo local
*.dockerignore  # Si el del proyecto es diferente al estándar

# Logs
*.log
logs/
server.log

# Environment variables - SECRETOS NO COMPARTIR
.env  # Variables de entorno con contraseñas reales
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database dump locales (opcional)
db-dumps/*.sql  # Solo si tienes datos sensibles, dejar V*__*.sql para estructura

# Testing coverage
coverage/
.nyc_output/
test-results.xml
junit.xml

# Temp files
*.tmp
.temp
backup.sql
